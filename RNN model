      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "import numpy as np\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. VERİ SETİ VE SÖZLÜK OLUŞTURMA\n",
        "sentences = [\n",
        "    [\"mühendis\", \"fabrika\", \"tasarım\", \"proje\", \"üretim\"],\n",
        "    [\"işçi\", \"fabrika\", \"üretim\", \"montaj\", \"hat\"],\n",
        "    [\"satın alma\", \"tedarikçi\", \"fiyat\", \"sözleşme\", \"pazarlık\"],\n",
        "    [\"müdür\", \"ofis\", \"yönetim\", \"toplantı\", \"lider\"]\n",
        "]\n",
        "\n",
        "vocab = list(set([word for seq in sentences for word in seq]))\n",
        "word_to_idx = {word: i for i, word in enumerate(vocab)}\n",
        "idx_to_word = {i: word for i, word in enumerate(vocab)}\n",
        "vocab_size = len(vocab)\n",
        "\n",
        "inputs = []\n",
        "targets = []\n",
        "for seq in sentences:\n",
        "    for i in range(len(seq) - 1):\n",
        "        inputs.append(word_to_idx[seq[i]])\n",
        "        targets.append(word_to_idx[seq[i+1]])\n",
        "\n",
        "def make_one_hot(idx, size):\n",
        "    x = np.zeros(size)\n",
        "    x[idx] = 1\n",
        "    return x\n",
        "\n",
        "X_one_hot = [make_one_hot(i, vocab_size) for i in inputs]\n",
        "X_tensor = torch.FloatTensor(X_one_hot).unsqueeze(1) # [Veri_Sayısı, 1, Vocab_Size]\n",
        "Y_tensor = torch.LongTensor(targets)\n",
        "\n",
        "# 2. RNN MİMARİSİ\n",
        "class SimpleRNN(nn.Module):\n",
        "    def __init__(self, input_size, hidden_size, output_size):\n",
        "        super(SimpleRNN, self).__init__()\n",
        "        self.hidden_size = hidden_size\n",
        "        self.rnn = nn.RNN(input_size, hidden_size, batch_first=False)\n",
        "        self.fc = nn.Linear(hidden_size, output_size)\n",
        "\n",
        "    def forward(self, x, hidden):\n",
        "        rnn_out, hidden = self.rnn(x, hidden)\n",
        "        output = self.fc(rnn_out.view(-1, self.hidden_size))\n",
        "        return output, rnn_out\n",
        "\n",
        "hidden_dim = 6\n",
        "model = SimpleRNN(vocab_size, hidden_dim, vocab_size)\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=0.01)\n",
        "\n",
        "# METRİKLERİ KAYDETMEK İÇİN LİSTELER\n",
        "loss_history = []\n",
        "accuracy_history = []\n",
        "hidden_norm_history = []\n",
        "gradient_norm_history = []\n",
        "\n",
        "# 3. MODELİN EĞİTİLMESİ\n",
        "epochs = 300\n",
        "for epoch in range(epochs):\n",
        "    hidden = torch.zeros(1, 1, hidden_dim)\n",
        "    optimizer.zero_grad()\n",
        "\n",
        "    # Forward Pass\n",
        "    output, rnn_outputs = model(X_tensor, hidden)\n",
        "    loss = criterion(output, Y_tensor)\n",
        "\n",
        "    # Backward Pass\n",
        "    loss.backward()\n",
        "\n",
        "    # --- GRADYAN NORMU TAKİBİ (Kaybolan/Patlayan Gradyan Analizi) ---\n",
        "    total_grad_norm = 0.0\n",
        "    for p in model.parameters():\n",
        "        if p.grad is not None:\n",
        "            param_norm = p.grad.data.norm(2) # L2 Norm hesaplama\n",
        "            total_grad_norm += param_norm.item() ** 2\n",
        "    total_grad_norm = total_grad_norm ** 0.5\n",
        "    gradient_norm_history.append(total_grad_norm)\n",
        "\n",
        "    # Optimizer Step\n",
        "    optimizer.step()\n",
        "\n",
        "    # --- DOĞRULUK (ACCURACY) HESAPLAMA ---\n",
        "    _, predicted = torch.max(output, 1)\n",
        "    correct = (predicted == Y_tensor).sum().item()\n",
        "    accuracy = correct / Y_tensor.size(0)\n",
        "\n",
        "    # --- GİZLİ DURUM NORMU HESAPLAMA (Sinyal Gücü) ---\n",
        "    # rnn_outputs: [Veri_Sayısı, 1, Hidden_Dim] -> Frobenius Normu\n",
        "    current_hidden_norm = torch.norm(rnn_outputs).item()\n",
        "\n",
        "    # Geçmişi kaydet\n",
        "    loss_history.append(loss.item())\n",
        "    accuracy_history.append(accuracy)\n",
        "    hidden_norm_history.append(current_hidden_norm)\n",
        "\n",
        "    if (epoch + 1) % 50 == 0:\n",
        "        print(f\"Epoch [{epoch+1}/{epochs}] -> Loss: {loss.item():.4f} | Acc: {accuracy:.2f} | Grad Norm: {total_grad_norm:.4f}\")\n",
        "\n",
        "print(\"\\nEğitim tamamlandı! Metrik analiz grafikleri çiziliyor...\\n\")\n",
        "\n",
        "# 4. GÖRSELLEŞTİRME: 4'LÜ METRİK PANELİ\n",
        "fig, axs = plt.subplots(2, 2, figsize=(14, 9))\n",
        "\n",
        "# A. Eğitim Kaybı (Loss Curve)\n",
        "axs[0, 0].plot(loss_history, color=\"crimson\", linewidth=2)\n",
        "axs[0, 0].set_title(\"Eğitim Kaybı (Loss)\")\n",
        "axs[0, 0].set_xlabel(\"Epoch\")\n",
        "axs[0, 0].grid(True, linestyle=\"--\", alpha=0.5)\n",
        "\n",
        "# B. Eğitim Doğruluğu (Accuracy Curve)\n",
        "axs[0, 1].plot(accuracy_history, color=\"forestgreen\", linewidth=2)\n",
        "axs[0, 1].set_title(\"Eğitim Doğruluğu (Accuracy)\")\n",
        "axs[0, 1].set_xlabel(\"Epoch\")\n",
        "axs[0, 1].set_ylim(-0.05, 1.05)\n",
        "axs[0, 1].grid(True, linestyle=\"--\", alpha=0.5)\n",
        "\n",
        "# C. Gizli Durum Normu (Hidden State Norm)\n",
        "axs[1, 0].plot(hidden_norm_history, color=\"royalblue\", linewidth=2)\n",
        "axs[1, 0].set_title(\"Gizli Durum Normu (Hidden State Frobenius Norm)\")\n",
        "axs[1, 0].set_xlabel(\"Epoch\")\n",
        "axs[1, 0].grid(True, linestyle=\"--\", alpha=0.5)\n",
        "\n",
        "# D. Gradyan Normu (Gradient Norm - Vanishing/Exploding Kontrolü)\n",
        "axs[1, 1].plot(gradient_norm_history, color=\"darkorange\", linewidth=2)\n",
        "axs[1, 1].set_title(\"Gradyan Normu (L2 Norm)\")\n",
        "axs[1, 1].set_xlabel(\"Epoch\")\n",
        "axs[1, 1].grid(True, linestyle=\"--\", alpha=0.5)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# 5. SINIF OLASILIKLARI (CLASS PROBABILITIES) GÖRSELLEŞTİRMESİ\n",
        "# Örnek test kelimesi olarak \"satın alma\" girdisini verip modelin olasılık dağılımına bakalım\n",
        "test_word = \"satın alma\"\n",
        "test_idx = word_to_idx[test_word]\n",
        "test_input_one_hot = torch.FloatTensor(make_one_hot(test_idx, vocab_size)).unsqueeze(0).unsqueeze(0) # [1, 1, Vocab_Size]\n",
        "\n",
        "model.eval()\n",
        "with torch.no_grad():\n",
        "    test_hidden = torch.zeros(1, 1, hidden_dim)\n",
        "    logits, _ = model(test_input_one_hot, test_hidden)\n",
        "    # Çıktıyı Softmax ile olasılık değerlerine (0-1 arasına) dönüştürüyoruz\n",
        "    probabilities = torch.softmax(logits, dim=1).squeeze().numpy()\n",
        "\n",
        "# Olasılık Bar Grafiği\n",
        "plt.figure(figsize=(12, 5))\n",
        "plt.bar(vocab, probabilities, color=\"teal\", edgecolor=\"black\", alpha=0.8)\n",
        "plt.title(f\"Girdi: '{test_word}' iken Modelin Bir Sonraki Kelime İçin Sınıf Olasılıkları\")\n",
        "plt.ylabel(\"Olasılık (Softmax Score)\")\n",
        "plt.xlabel(\"Sözlükteki Kelimeler (Classes)\")\n",
        "plt.xticks(rotation=45, ha=\"right\")\n",
        "plt.ylim(0, 1.05)\n",
        "plt.grid(axis='y', linestyle=\"--\", alpha=0.5)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
