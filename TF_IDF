        "# 0. Colab için Gensim kütüphanesini yüklüyoruz\n",
        "!pip install gensim\n",
        "\n",
        "import string\n",
        "import warnings\n",
        "from gensim.models import Word2Vec\n",
        "from collections import defaultdict\n",
        "\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# 1. Ham Metin Girişi\n",
        "ham_metin = (\n",
        "    \"Sayın Emine Erdoğan Hanımefendi'nin himayelerinde her yıl farklı bir konseptle düzenlenen \"\n",
        "    \"Türk Mutfağı Haftası'nın bu yılki temasının 'Bir Sofrada Miras' olarak belirlendiği, \"\n",
        "    \"hafta kapsamında yurt içinde ve yurt dışında düzenlenecek etkinliklere dair hazırlanan rehberlerin \"\n",
        "    \"ekte sunulduğu, Türk Mutfağı Haftası kapsamında bu yıl da aşağıda linki yer alan internet sayfasının \"\n",
        "    \"aktif olarak kullanılacağı, sayfanın güncellenme çalışmaları devam ettiği, planlanan etkinliklerde \"\n",
        "    \"ihtiyaç duyulacak her türlü tanıtım materyaline (logo, poster, afiş, görsel vb.) anılan internet \"\n",
        "    \"sayfası üzerinden erişim sağlanabileceği, Türk Mutfağı Haftası'na ilişkin bilgi talepleri, \"\n",
        "    \"Bakanlıkları Türkiye Turizm Tanıtım ve Geliştirme Ajansı Genel Müdürlüğü’nün tmh@tga.gov.tr \"\n",
        "    \"e-posta adresine iletilebileceği ifade edilmektedir.\"\n",
        ")\n",
        "\n",
        "# 2. TOKENIZE Fonksiyonu ve KORPUS (Corpus) Oluşturma\n",
        "def tokenize(text):\n",
        "    \"\"\"Metni temizler, küçük harfe çevirir ve kelime token'larına ayırır.\"\"\"\n",
        "    temiz_metin = text.translate(str.maketrans('', '', string.punctuation)).lower()\n",
        "    return temiz_metin.split()\n",
        "\n",
        "# Korpusumuzu açıkça tokenize fonksiyonundan geçirerek oluşturuyoruz\n",
        "tokenized_text = tokenize(ham_metin)\n",
        "korpus = [tokenized_text]  # Word2Vec için liste içinde liste formatı\n",
        "\n",
        "print(f\"Tokenize Edildi. Toplam Kelime (Token) Sayısı: {len(tokenized_text)}\")\n",
        "\n",
        "# 3. CO-OCCURRENCE (Birlikte Geçme) Analiz Fonksiyonu\n",
        "# Word2Vec'in eğitime başlamadan önce context içinde neyi gördüğünü anlamak için manuel bir cooc sayıcı ekleyelim\n",
        "def get_cooccurrences(tokens, target_word, window_size=3):\n",
        "    \"\"\"Hedef kelimenin belirlenen context penceresinde hangi kelimelerle kaç kez yan yana geldiğini (co-occurrence) sayar.\"\"\"\n",
        "    cooc_counts = defaultdict(int)\n",
        "    for i, token in enumerate(tokens):\n",
        "        if token == target_word:\n",
        "            # Pencere sınırlarını korpus dışına taşmayacak şekilde belirliyoruz\n",
        "            sol_sinir = max(0, i - window_size)\n",
        "            sag_sinir = min(len(tokens), i + window_size + 1)\n",
        "\n",
        "            # Bağlamdaki (Context) kelimeleri tarıyoruz\n",
        "            for j in range(sol_sinir, sag_sinir):\n",
        "                if i != j:  # Kelimenin kendisini sayma\n",
        "                    cooc_counts[tokens[j]] += 1\n",
        "    return dict(sorted(cooc_counts.items(), key=lambda item: item[1], reverse=True))\n",
        "\n",
        "# 4. Model Parametrelerinin Tanımlanması (CBOW / Skip-gram)\n",
        "vektor_boyutu = 50\n",
        "pencere_boyutu = 3   # CONTEXT Penceresi: Sağdan 3, soldan 3 kelimeye bakacak\n",
        "\n",
        "# Algoritma seçimi: sg=0 -> CBOW, sg=1 -> Skip-gram (s_gram)\n",
        "secilen_mimari = 1\n",
        "print(f\"Model Eğitiliyor... Mimari: {'Skip-gram (s_gram)' if secilen_mimari == 1 else 'CBOW'}\\n\" + \"-\"*50)\n",
        "\n",
        "# 5. Word2Vec Modelinin Eğitilmesi\n",
        "model = Word2Vec(\n",
        "    sentences=korpus,\n",
        "    vector_size=vektor_boyutu,\n",
        "    window=pencere_boyutu,\n",
        "    sg=secilen_mimari,\n",
        "    min_count=1,\n",
        "    workers=4\n",
        ")\n",
        "\n",
        "# 6. CO-OCCURRENCE ve WORD2VEC KARŞILAŞTIRMALI ANALİZİ\n",
        "def analiz_et(hedef_kelime):\n",
        "    print(f\"\\n=== '{hedef_kelime.upper()}' KELİMESİ İÇİN ANALİZ ===\")\n",
        "\n",
        "    # A. Adım: Korpus üzerindeki ham Co-occurrence (Eş Oluşum) durumları\n",
        "    coocs = get_cooccurrences(tokenized_text, hedef_kelime, window_size=pencere_boyutu)\n",
        "    print(f\"1. Ham Co-occurrence (Context Penceresindeki Komşular ve Frekansları):\")\n",
        "    for k, v in list(coocs.items())[:3]:  # İlk 3'ünü gösterelim\n",
        "        print(f\"   - '{k}' kelimesiyle {v} kez aynı pencerede denk geldi.\")\n",
        "\n",
        "    # B. Adım: Word2Vec'in bu co-occurrence ilişkilerinden çıkardığı vektör benzerliği\n",
        "    print(f\"\\n2. Word2Vec Vektör Alanındaki En Yakın Komşular:\")\n",
        "    try:\n",
        "        benzerler = model.wv.most_similar(hedef_kelime, topn=3)\n",
        "        for sira, (komsu, skor) in enumerate(benzerler, 1):\n",
        "            print(f\"   {sira}. Komşu: {komsu} (Benzerlik Skoru: {skor:.4f})\")\n",
        "    except KeyError:\n",
        "        print(f\"   '{hedef_kelime}' kelimesi korpusta yok.\")\n",
        "\n",
        "# Analizi başlatalım\n",
        "analiz_et(\"türk\")\n",
        "analiz_et(\"internet\")"
      ],
